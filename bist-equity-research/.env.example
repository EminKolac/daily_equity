# Copy to .env and fill in your actual keys

# Anthropic (Claude API for LLM narratives)
ANTHROPIC_API_KEY=sk-ant-xxx

# TCMB EVDS (macro data)
TCMB_EVDS_API_KEY=your_tcmb_key

# Apify (Twitter/X scraping)
APIFY_API_TOKEN=apify_api_xxx

# Email (SMTP for report delivery)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
REPORT_RECIPIENT=mehmetemin.kolac@tvf.com.tr
