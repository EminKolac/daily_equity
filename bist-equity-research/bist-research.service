[Unit]
Description=BIST Equity Research Weekly Report Generator
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/user/daily_equity/bist-equity-research
ExecStart=/usr/local/bin/python3 scheduler.py
Restart=on-failure
RestartSec=60
EnvironmentFile=/home/user/daily_equity/bist-equity-research/.env

[Install]
WantedBy=multi-user.target
